{
  "name": "lyra-sync-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:native": "turbo run dev -F native",
    "dev:web": "turbo run dev -F web",
    "dev:desktop": "pnpm --filter desktop dev",
    "peer-server": "pnpm --filter @lyra-sync-app/net peer-server",
    "test": "pnpm --filter @lyra-sync-app/net test && pnpm --filter @lyra-sync-app/core test",
    "test:pair": "pnpm --filter @lyra-sync-app/core exec tsx scripts/pair-local.mjs",
    "dev:pair-a": "LYRA_ALLOW_MULTI=1 LYRA_INSTANCE=a LYRA_PORT=53317 LYRA_NAME='Computer A' pnpm --filter desktop dev",
    "dev:pair-b": "LYRA_ALLOW_MULTI=1 LYRA_INSTANCE=b LYRA_PORT=53319 LYRA_NAME='Computer B' pnpm --filter desktop dev",
    "test:e2e": "pnpm --filter web test:e2e",
    "deploy:setup": "vercel link",
    "dev:vercel": "vercel dev -L",
    "env:preview": "tsx scripts/sync-vercel-env.ts preview",
    "env:production": "tsx scripts/sync-vercel-env.ts production",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "deploy:check": "vercel deploy --dry",
    "check": "biome check --write .",
    "pack:desktop": "pnpm --filter web build && pnpm --filter desktop pack",
    "dist:desktop": "pnpm --filter web build && pnpm --filter desktop dist",
    "eas:android:preview": "cd apps/native && eas build --platform android --profile preview --non-interactive --no-wait"
  },
  "dependencies": {
    "@lyra-sync-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@lyra-sync-app/config": "workspace:*",
    "@types/node": "^22.13.14",
    "tsx": "^4.22.5",
    "turbo": "^2.10.2",
    "typescript": "^6",
    "vercel": "^54.18.6"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "zxing-wasm": "link:apps/native/vendor/zxing-wasm-stub"
    },
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "@parcel/watcher",
      "unrs-resolver"
    ]
  }
}
