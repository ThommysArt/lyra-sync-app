{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_VARIANT": "development",
        "EXPO_PUBLIC_LYRA_ENV": "development",
        "EXPO_PUBLIC_SERVER_URL": "https://lyra.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_LYRA_ENV": "preview",
        "EXPO_PUBLIC_SERVER_URL": "https://lyra.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_LYRA_ENV": "production",
        "EXPO_PUBLIC_SERVER_URL": "https://lyra.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
