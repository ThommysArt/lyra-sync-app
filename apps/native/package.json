{
  "name": "native",
  "version": "0.2.3",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "APP_VARIANT=development expo start --clear",
    "dev:preview": "APP_VARIANT=preview expo start --clear",
    "web": "expo start --web",
    "android": "APP_VARIANT=development expo run:android",
    "ios": "APP_VARIANT=development expo run:ios",
    "prebuild": "expo prebuild --platform android --non-interactive",
    "prebuild:dev": "APP_VARIANT=development expo prebuild --platform android --clean --non-interactive",
    "prebuild:preview": "APP_VARIANT=preview expo prebuild --platform android --clean --non-interactive",
    "prebuild:prod": "APP_VARIANT=production expo prebuild --platform android --clean --non-interactive",
    "build:dev": "APP_VARIANT=development node scripts/build-apk.mjs debug",
    "build:preview": "APP_VARIANT=preview node scripts/build-apk.mjs release",
    "build:prod": "APP_VARIANT=production node scripts/build-apk.mjs release",
    "install:dev": "node scripts/install-apk.mjs development",
    "install:preview": "node scripts/install-apk.mjs preview",
    "install:prod": "node scripts/install-apk.mjs production",
    "eas:dev": "APP_VARIANT=development eas build --platform android --profile development",
    "eas:preview": "APP_VARIANT=preview eas build --platform android --profile preview",
    "eas:prod": "APP_VARIANT=production eas build --platform android --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo/metro-runtime": "~57.0.2",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@lyra-sync-app/core": "workspace:*",
    "@lyra-sync-app/env": "workspace:*",
    "@lyra-sync-app/hooks": "workspace:*",
    "@lyra-sync-app/net": "workspace:*",
    "@lyra-sync-app/protocol": "workspace:*",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "dotenv": "catalog:",
    "expo": "~57.0.1",
    "expo-blur": "~57.0.0",
    "expo-camera": "~57.0.1",
    "expo-clipboard": "^57.0.1",
    "expo-constants": "~57.0.2",
    "expo-dev-client": "^57.0.7",
    "expo-document-picker": "^57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-network": "~57.0.0",
    "expo-router": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "heroui-native": "^1.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-tcp-socket": "6.4.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "catalog:",
    "uniwind": "^1.10.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@lyra-sync-app/config": "workspace:*",
    "@types/node": "^26.0.1",
    "@types/react": "~19.2.17",
    "typescript": "~6.0.3"
  }
}
