{
  "name": "native",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --clear",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:android": "expo prebuild --platform android",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:clean": "expo prebuild --clean",
    "android": "expo run:android",
    "android:device": "expo run:android --device",
    "android:release": "expo run:android --variant release",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "ios:release": "expo run:ios --configuration Release",
    "build:android": "pnpm run prebuild:android && cd android && ./gradlew assembleRelease",
    "build:android:debug": "pnpm run prebuild:android && cd android && ./gradlew assembleDebug",
    "build:android:bundle": "pnpm run prebuild:android && cd android && ./gradlew bundleRelease",
    "build:ios": "pnpm run prebuild:ios && xcodebuild -workspace ios/Lyra.xcworkspace -scheme Lyra -configuration Release -sdk iphoneos -derivedDataPath ios/build",
    "install:android": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "install:android:debug": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "eas:android:preview": "eas build --platform android --profile preview",
    "eas:android:dev": "eas build --platform android --profile development",
    "eas:android:production": "eas build --platform android --profile production",
    "eas:ios:preview": "eas build --platform ios --profile preview",
    "eas:ios:dev": "eas build --platform ios --profile development",
    "eas:ios:production": "eas build --platform ios --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo/metro-runtime": "~57.0.2",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@lyra-sync-app/core": "workspace:*",
    "@lyra-sync-app/env": "workspace:*",
    "@lyra-sync-app/hooks": "workspace:*",
    "@lyra-sync-app/protocol": "workspace:*",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "dotenv": "catalog:",
    "expo": "~57.0.1",
    "expo-blur": "~57.0.0",
    "expo-camera": "~57.0.1",
    "expo-clipboard": "^57.0.1",
    "expo-constants": "~57.0.2",
    "expo-dev-client": "^57.0.7",
    "expo-document-picker": "^57.0.1",
    "expo-file-system": "~19.0.23",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.1",
    "expo-network": "~57.0.0",
    "expo-router": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "heroui-native": "^1.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "catalog:",
    "uniwind": "^1.10.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@lyra-sync-app/config": "workspace:*",
    "@types/node": "^26.0.1",
    "@types/react": "~19.2.17",
    "typescript": "~6.0.3"
  }
}
